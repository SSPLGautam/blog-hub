@using System.Security.Claims
@using BlogApp.Web.Helper
@using BlogApp.Web.ViewModel
@model PostViewModel

@{
    ViewData["Title"] = "Post Detail";

    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwner = Model.CreatedByUserId == currentUserId;
    var isAdmin = User.IsInRole("Admin");
    
    var isLiked = User.Identity.IsAuthenticated &&
                  Model.Likes.Any(x => x.UserId == currentUserId);
}

<style>
    .content-wrapper {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
        font-family: sans-serif;
    }
    .comment-card{
    border-radius:12px;
}

.avatar{
    width:35px;
    height:35px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:14px;
}

    .feature_image {
        width: 100%;
        height: 500px;
        object-fit: cover;
        margin-bottom: 20px;
    }
</style>

<div class="content-wrapper">
        <!-- POST MANAGEMENT BUTTONS -->
    @if (User.Identity.IsAuthenticated && (isAdmin || isOwner))
    {
        <div class="text-end">

            <a asp-action="Edit"
               asp-controller="Post"
               asp-route-id="@Model.Id"
               class="btn btn-secondary mx-2 my-3">
                Edit Post
            </a>

            <a asp-action="Delete"
               asp-controller="Post"
               asp-route-id="@Model.Id"
               class="btn btn-danger mx-2 my-3">
                Delete Post
            </a>
                        
            <button id="publishBtn"
                      
                    class="btn @(Model.IsPublished ? "btn-warning" : "btn-success") mx-1">
                @(Model.IsPublished ? "Unpublish" : "Publish")
            </button>

        </div>
    }

    <!-- POST CONTENT -->
                          
    <h1>@Model.Title</h1>

    <p>
        <span class="badge bg-primary">By:</span> @Model.Authore |
        <span class="badge bg-primary">Published on</span>
        @Model.PublishedDate.ToString("MMMM dd yyyy")
    </p>

    <p>
        <span class="badge bg-secondary">Category</span>
        @Model.Category.Name
    </p>

    <img src="@Model.FeatureImagePath"
         alt="@Model.Title"
         class="feature_image" />

    <hr />

    <div>
        @Html.Raw(Model.Content)
    </div>

    <hr />

    <!-- LIKE SECTION -->

    @if (User.Identity.IsAuthenticated)
    {
        <div class="mb-3">

            <button id="likeBtn"
                    class="btn btn-sm @(isLiked ? "btn-danger" : "btn-outline-danger")">
                    <input type="hidden" id="PostId" value="@Model.Id" />

                @if (isLiked)
                {
                    <i class="fa-regular fa-heart"></i> <text>Unlike</text>
                }
                else
                {
                    <i class="fa-solid fa-heart"></i> <text>Like</text>
                }

            </button>

            <span id="likeCount" class="ms-2 fw-bold">
                @Model.Likes.Count() Likes
            </span>

        </div>
    }
    else
    {
        <div class="mb-3">
            <span class="fw-bold">@Model.Likes.Count() Likes</span>
        </div>
    }

    <hr />

    <div id="commentSection">
        <partial name="PostCommentsList" model="Model.Comments" />
    </div>    

    <div id="commentformSection">
        @await Html.PartialAsync("AddCommentForm",new AddCommentFormViewModel(){PostId = Model.Id})
    </div> 
    
</div>    

@section Scripts {
    
    <script src="~/js/comment.js"></script>

}